{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pcs.sentinelops.ci/schemas/PFCoreKernelManifest.v0.schema.json",
  "title": "PFCoreKernelManifest.v0",
  "description": "Closed per-file inventory of PF-Core Lean kernel sources bundled for offline validation.",
  "type": "object",
  "required": [
    "schema_version",
    "artifact_type",
    "files"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "$ref": "common.defs.json#/$defs/schema_version" },
    "artifact_type": { "const": "PFCoreKernelManifest.v0" },
    "canonicalization_version": {
      "$ref": "common.defs.json#/$defs/canonicalization_version"
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "maxItems": 512,
      "uniqueItems": true,
      "items": { "$ref": "common.defs.json#/$defs/kernel_file_entry" }
    },
    "signature_or_digest": {
      "$ref": "common.defs.json#/$defs/hex_digest",
      "description": "v0 compatibility integrity digest of the manifest (Canonical JSON v1)."
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pcs.sentinelops.ci/schemas/SemanticCheckExecution.v0.schema.json",
  "title": "SemanticCheckExecution.v0",
  "type": "object",
  "required": [
    "schema_version",
    "policy_id",
    "policy_version",
    "severity_definitions",
    "checks",
    "signature_or_digest"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "$ref": "common.defs.json#/$defs/schema_version" },
    "policy_id": { "type": "string", "minLength": 1 },
    "policy_version": { "type": "string", "minLength": 1 },
    "severity_definitions": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": { "$ref": "#/$defs/severity_definition" }
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/execution_check" }
    },
    "signature_or_digest": { "$ref": "common.defs.json#/$defs/hex_digest" }
  },
  "$defs": {
    "severity_definition": {
      "type": "object",
      "required": ["description", "fatal_if_skipped_in_release_mode"],
      "additionalProperties": false,
      "properties": {
        "description": { "type": "string", "minLength": 1 },
        "fatal_if_skipped_in_release_mode": { "type": "boolean" },
        "downstream_must_report_execution": { "type": "boolean" }
      }
    },
    "execution_check": {
      "type": "object",
      "required": [
        "registry_ref",
        "artifact_type",
        "check_id",
        "severity",
        "responsible_component",
        "execution_required_in_release_mode",
        "allowed_to_skip",
        "enforcement_layer"
      ],
      "additionalProperties": false,
      "properties": {
        "registry_ref": { "type": "string", "minLength": 1 },
        "artifact_type": { "type": "string", "minLength": 1 },
        "check_id": { "type": "string", "minLength": 1 },
        "severity": { "$ref": "common.defs.json#/$defs/semantic_check_severity" },
        "responsible_component": { "type": "string", "minLength": 1 },
        "execution_required_in_release_mode": { "type": "boolean" },
        "allowed_to_skip": { "type": "boolean" },
        "enforcement_layer": {
          "type": "string",
          "enum": [
            "artifact_validate",
            "release_chain",
            "consumer",
            "registry_metadata"
          ]
        }
      }
    }
  }
}

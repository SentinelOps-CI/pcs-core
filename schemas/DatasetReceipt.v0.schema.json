{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pcs.sentinelops.ci/schemas/DatasetReceipt.v0.schema.json",
  "title": "DatasetReceipt.v0",
  "type": "object",
  "required": [
    "schema_version",
    "dataset_id",
    "dataset_name",
    "dataset_version",
    "files",
    "aggregate_hash",
    "source_uri",
    "source_repo",
    "source_commit",
    "license",
    "created_at",
    "signature_or_digest"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "$ref": "common.defs.json#/$defs/schema_version" },
    "dataset_id": { "type": "string", "minLength": 1 },
    "dataset_name": { "type": "string", "minLength": 1 },
    "dataset_version": { "type": "string", "minLength": 1 },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/dataset_file" }
    },
    "aggregate_hash": { "$ref": "common.defs.json#/$defs/hex_digest" },
    "source_uri": { "type": "string", "minLength": 1 },
    "source_repo": { "type": "string", "format": "uri" },
    "source_commit": { "$ref": "common.defs.json#/$defs/git_commit" },
    "license": { "type": "string", "minLength": 1 },
    "created_at": { "$ref": "common.defs.json#/$defs/iso8601_datetime" },
    "signature_or_digest": { "$ref": "common.defs.json#/$defs/hex_digest" }
  },
  "$defs": {
    "dataset_file": {
      "type": "object",
      "required": ["path", "sha256", "size_bytes", "media_type"],
      "additionalProperties": false,
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "sha256": { "$ref": "common.defs.json#/$defs/hex_digest" },
        "size_bytes": { "type": "integer", "minimum": 0 },
        "media_type": { "type": "string", "minLength": 1 }
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pcs.sentinelops.ci/schemas/ComponentReleaseFragment.v0.schema.json",
  "title": "ComponentReleaseFragment.v0",
  "type": "object",
  "required": [
    "schema_version",
    "component",
    "source_repo",
    "source_commit",
    "artifacts",
    "signature_or_digest"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^v0$"
    },
    "component": {
      "type": "string",
      "minLength": 1
    },
    "source_repo": {
      "type": "string",
      "format": "uri"
    },
    "source_commit": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "artifacts": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["artifact_type", "sha256"],
        "additionalProperties": false,
        "properties": {
          "artifact_type": { "type": "string", "minLength": 1 },
          "sha256": {
            "type": "string",
            "pattern": "^sha256:[a-f0-9]{64}$"
          }
        }
      }
    },
    "signature_or_digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    }
  }
}

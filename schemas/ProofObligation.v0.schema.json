{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pcs.sentinelops.ci/schemas/ProofObligation.v0.schema.json",
  "title": "ProofObligation.v0",
  "type": "object",
  "required": [
    "schema_version",
    "obligation_id",
    "release_id",
    "workflow_id",
    "obligations",
    "source_artifacts",
    "lean_module",
    "source_repo",
    "source_commit",
    "signature_or_digest"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "$ref": "common.defs.json#/$defs/schema_version" },
    "obligation_id": { "type": "string", "minLength": 1 },
    "release_id": { "type": "string", "minLength": 1 },
    "workflow_id": { "type": "string", "minLength": 1 },
    "obligations": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/proof_obligation_entry" }
    },
    "source_artifacts": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["path", "artifact_type"],
        "additionalProperties": false,
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "artifact_type": { "type": "string", "minLength": 1 }
        }
      }
    },
    "pcs_projection_manifest": {
      "$ref": "PCSProjectionManifest.v0.schema.json"
    },
    "pcs_projection_manifest_hash": {
      "$ref": "common.defs.json#/$defs/hex_digest"
    },
    "lean_module": { "type": "string", "minLength": 1 },
    "source_repo": { "type": "string", "format": "uri" },
    "source_commit": { "$ref": "common.defs.json#/$defs/git_commit" },
    "signature_or_digest": { "$ref": "common.defs.json#/$defs/hex_digest" }
  },
  "$defs": {
    "proof_obligation_entry": {
      "type": "object",
      "required": ["obligation_id", "kind", "inputs"],
      "additionalProperties": false,
      "properties": {
        "obligation_id": { "type": "string", "minLength": 1 },
        "kind": { "type": "string", "minLength": 1 },
        "inputs": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": true
        }
      }
    }
  }
}

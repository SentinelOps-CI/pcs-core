{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pcs.sentinelops.ci/schemas/ReleaseManifest.v0.schema.json",
  "title": "ReleaseManifest.v0",
  "type": "object",
  "required": [
    "schema_version",
    "release_id",
    "release_candidate",
    "generated_at",
    "validation_profile",
    "workflow_profile_id",
    "producer_repos",
    "artifacts",
    "release_status",
    "chain_root",
    "release_chain_validation_result",
    "canonical_signed_bundle",
    "canonical_claim_id",
    "limitations_notice",
    "signature_or_digest"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "$ref": "common.defs.json#/$defs/schema_version" },
    "release_id": { "type": "string", "minLength": 1 },
    "release_candidate": { "type": "string", "minLength": 1 },
    "generated_at": { "$ref": "common.defs.json#/$defs/iso8601_datetime" },
    "validation_profile": { "type": "string", "minLength": 1 },
    "workflow_profile_id": { "type": "string", "minLength": 1 },
    "producer_repos": {
      "type": "object",
      "required": ["pcs_core"],
      "minProperties": 1,
      "additionalProperties": { "$ref": "common.defs.json#/$defs/producer_repo_pin" },
      "properties": {
        "pcs_core": { "$ref": "common.defs.json#/$defs/producer_repo_pin" },
        "labtrust_gym": { "$ref": "common.defs.json#/$defs/producer_repo_pin" },
        "certifyedge": { "$ref": "common.defs.json#/$defs/producer_repo_pin" },
        "provability_fabric": { "$ref": "common.defs.json#/$defs/producer_repo_pin" },
        "scientific_memory": { "$ref": "common.defs.json#/$defs/producer_repo_pin" },
        "agent_runtime": { "$ref": "common.defs.json#/$defs/producer_repo_pin" }
      }
    },
    "artifacts": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "common.defs.json#/$defs/manifest_artifact_entry"
      }
    },
    "release_status": { "$ref": "common.defs.json#/$defs/release_status" },
    "chain_root": { "$ref": "common.defs.json#/$defs/chain_root" },
    "release_chain_validation_result": {
      "$ref": "common.defs.json#/$defs/manifest_path_ref"
    },
    "canonical_signed_bundle": {
      "$ref": "common.defs.json#/$defs/manifest_path_ref"
    },
    "canonical_claim_id": { "type": "string", "minLength": 1 },
    "limitations_notice": {
      "$ref": "common.defs.json#/$defs/limitations_notice"
    },
    "proof_obligation": {
      "$ref": "common.defs.json#/$defs/manifest_path_ref"
    },
    "lean_check_result": {
      "$ref": "common.defs.json#/$defs/manifest_path_ref"
    },
    "signature_or_digest": { "$ref": "common.defs.json#/$defs/hex_digest" }
  }
}
